generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Note {
  id        String   @id @default(uuid())
  text      String
  chatMessages Json?
  token     String   @unique @default(uuid())
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  title     String?
  author    User     @relation(fields: [authorId], references: [id])
}

model WeeklyStreak {
  id        String   @id @default(uuid())
  userId    String
  weekStart DateTime
  sunday    Boolean  @default(false)
  monday    Boolean  @default(false)
  tuesday   Boolean  @default(false)
  wednesday Boolean  @default(false)
  thursday  Boolean  @default(false)
  friday    Boolean  @default(false)
  saturday  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
}

model UserStreakHistory {
  id          String   @id @default(uuid())
  userId      String   @unique
  bestStreak  Int      @default(0)
  totalWeeks  Int      @default(0)
  lastUpdated DateTime @default(now()) @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WeeklyReport {
  id          String   @id @default(uuid())
  userId      String
  weekStart   DateTime
  reportText  String
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
  @@index([weekStart])
}

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  firstName     String?
  lastName      String?
  isGuest       Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @default(now()) @updatedAt
  dob           DateTime?
  timezone      String?            @default("UTC")
  Neuroscience    Neuroscience[]
  workouts        Workout[]
  workoutProfile  WorkoutProfile?
  workoutPrograms WorkoutProgram[]
  notes           Note[]
  streakHistory   UserStreakHistory?
  weeklyReports   WeeklyReport[]
  weeklyStreaks    WeeklyStreak[]
}

model RateLimitAttempt {
  id                  String    @id @default(uuid())
  identifier          String
  actionType          String
  attemptCount        Int       @default(1)
  consecutiveLockouts Int       @default(0)
  lockedUntil         DateTime?
  lastAttempt         DateTime  @default(now())
  requiresCaptcha     Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @default(now()) @updatedAt

  @@unique([identifier, actionType])
  @@index([identifier])
  @@index([actionType])
  @@index([lockedUntil])
}

model SecurityAuditLog {
  id            String   @id @default(uuid())
  eventType     String
  ipAddress     String
  email         String?
  userAgent     String?
  country       String?
  failureReason String?
  metadata      String?
  createdAt     DateTime @default(now())

  @@index([eventType])
  @@index([ipAddress])
  @@index([email])
  @@index([createdAt])
}

model Neuroscience {
  id        String   @id
  text      String
  chatMessages Json?
  token     String   @unique(map: "Neuroscience_token_idx")
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  title     String?
  User      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Workout {
  id        String   @id
  text      String
  chatMessages Json?
  token     String   @unique(map: "Workout_token_idx")
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  title     String?
  User      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model WorkoutProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  goal                  String
  lifestyleConstraints  String?
  nutritionBaseline     String?
  trainingHistoryLevel  String
  gymDaysPerWeek        Int
  timelineWeeks         Int
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("workout_profiles")
}

model WorkoutProgram {
  id        String   @id @default(uuid())
  userId    String
  title     String
  startDate DateTime
  endDate   DateTime
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("workout_programs")
}
