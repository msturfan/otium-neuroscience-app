{
  "name": "otium",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "migrate": "dotenv -e .env.local -- npx prisma generate && dotenv -e .env.local -- npx prisma migrate dev",
